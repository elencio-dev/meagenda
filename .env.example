# Banco de Dados (PostgreSQL via Prisma / Neon)
DATABASE_URL="postgres://usuario:senha@host:5432/bd?sslmode=require"

# Autenticação (Better Auth)
BETTER_AUTH_URL="http://localhost:3000" # Em produção, use o domínio real
BETTER_AUTH_SECRET="INSIRA_UM_SEGREDO_FORTE_AQUI" # (rode `openssl rand -base64 32`)

# Nodemailer / Envio de Emails SMTP
EMAIL_USER="seu-email@gmail.com"
EMAIL_PASS="SENHA_DE_APLICATIVO_GMAIL"
CRON_SECRET="SEGREDO_PARA_PROTEGER_O_CRON"

# ─── E2E Test Variables (Apenas para ambiente local / CI) ───────────────────
E2E_BASE_URL="http://localhost:3000"
E2E_TEST_SLUG="salao-teste-e2e"
E2E_ADMIN_EMAIL="teste@meagenda.com.br"
E2E_ADMIN_PASSWORD="Teste@1234"
